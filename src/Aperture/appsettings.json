{
  "Site": {
    "Name": "Aperture",
    "Copyright": {
      "Notice": "Aperture - All rights reserved",
      "StartYear": 2022
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DbSettings": {
    "Contexts": {
      "ApertureDb": {
        "Name": "ApertureDb",
        "ConnectionString": "{SqlServer-Connection-String}",
        "EnableAutomaticMigrations": true,
        "EnableDataSeeding": true
      }
    },
    "SeedData": {
      "PhotoCount": 84
    }
  },
  "Photos": {
    "Sizing": {
      "Landscape": {
        "Full": 1920,
        "Large": 960,
        "Small": 480,
        "Thumb": 320,
        "Icon": 64
      },
      "Portrait": {
        "Full": 1280,
        "Large": 640,
        "Small": 320,
        "Thumb": 320,
        "Icon": 64
      },
      "Square": {
        "Full": 1280,
        "Large": 640,
        "Small": 320,
        "Thumb": 320,
        "Icon": 64
      }
    }
  },
  "ExifOverrides": {
    "Mappings": {
      "Model": {
        "EOS M50m2": "EOS M50 Mark II"
      },
      "LensModel": {
        "EF-M15-45mm f/3.5-6.3 IS STM":  "Canon EF-M 15-45mm f/3.5-6.3 IS STM",
        "EF-M55-200mm f/4.5-6.3 IS STM": "Canon EF-M 55-200mm f/4.5-6.3 IS STM"
      }
    }
  },
  "Authentication": {
    "Domain": "{Auth0-Domain}",
    "ClientId": "{Auth0-ClientId}"
  },
  "AllowedHosts": "*"
}
