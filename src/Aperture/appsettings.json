{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "SiteName": "Saucy Photographer",
    "CopyrightOwner": "Saucy Photographer",
    "BrandIcon": "Camera"
  },
  "Auth0": {
    "Domain": "YOUR_AUTH0_DOMAIN",
    "ClientId": "YOUR_AUTH0_CLIENT_ID",
    "ClientSecret": "YOUR_AUTH0_CLIENT_SECRET"
  },
  "Jwt": {
    "Issuer": "https://dotnetninja.net/",
    "Audience": "https://dotnetninja.net/",
    "SigningKey": "Some_Secret_Key_That_Is_At_Least_32_Characters_Long", // Must be at least 32 characters long
    "ExpirationMinutes": 60
  }
}
